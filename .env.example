# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-use-openssl-rand-hex-32
API_KEY=yasml-dev-key

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=yasml
POSTGRES_USER=yasml
POSTGRES_PASSWORD=yasml_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-3.0-flash

# ─── GitHub (optional, for private repos) ─────────────────────────────────────
GITHUB_TOKEN=

# ─── Storage ──────────────────────────────────────────────────────────────────
REPOS_STORAGE_PATH=/tmp/yasml-repos
